{
    "name": "monitoring/minecraft",
    "description": "Minecraft Server Monitoring Platform",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^7.0",
        "react/event-loop": "^1.6",
        "react/socket": "^1.17",
        "react/mysql": "^0.6.0",
        "react/promise": "^3.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    }
}
